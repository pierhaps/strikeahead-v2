    "features": { "title": "Gjithçka ju nevojitet për peshkim më të mirë", "1_title": "Logger kapjesh me IA", "1_desc": "Bëni një foto — IA identifikon specien, regjistron masat dhe llogarit automatikisht Strike Score.", "2_title": "Parashikim kapjesh & baticash", "2_desc": "Fazat solunare, kalendarët e baticave, parashikimet e erës dhe tendencat e presionit për momentin e përsosur.", "3_title": "Inteligjenca e karremit", "3_desc": "Aplikacioni analizon kapjet tuaja dhe rekomandon karremin optimal sipas sezonit, ujit dhe motit.", "4_title": "Sistemi Trust Score", "4_desc": "Kapje të verifikuara me GPS & foto. Vlerësim transparent i komunitetit — i drejtë dhe i pamundur të falsifikohet.", "5_title": "Menaxheri i licencave", "5_desc": "Licenca peshkimi për 14 vende drejtpërdrejt në aplikacion. Bleni, ruani dhe tregojini pa letërsi.", "6_title": "Komuniteti & trajnerët", "6_desc": "Ekuipazhe, turneut, bisedë live dhe trajnerë profesionistë për seancën tuaj të radhës." },
    "how": { "label": "Si funksionon", "title": "Tre hapa drejt strike-ut të përsosur", "1_title": "Regjistro kapjen tënde", "1_desc": "Bëj foto, konfirmo specien, fut masat. Në pak se 60 sekonda kapja dokumentohet me mot, GPS dhe karrem.", "2_title": "IA mëson profilin tënd", "2_desc": "Pas çdo kapjeje, profili juaj personal i aftësive rafinohet. IA analizon modelet e sukseseve dhe dështimeve tuaja.", "3_title": "Aplikacioni të thotë kur & ku", "3_desc": "Parashikime të personalizuara Strike Score: cili peshk kafshon, në cilën pikë, me cilin karrem? StrikeAhead e di." },
    "testimonials": { "label": "Dëshmi", "title": "Çfarë thonë peshkatarët", "1_name": "Lars Bergmann", "1_role": "Peshkatar hobist, Hamburg", "1_text": "Që kur përdor StrikeAhead, shkalla ime e kapjeve u dyfishua. Parashikimet e IA janë befasisht të sakta.", "2_name": "Maria Hoffmann", "2_role": "Peshkatare deti, Kiel", "2_text": "Menaxheri i licencave vetëm ia vlen abonimin. Peshkoj në 5 vende të ndryshme dhe tashmë i kam të gjitha licencat në një vend.", "3_name": "Stefan Kowalczyk", "3_role": "Peshkatar turneu, Mynih", "3_text": "Trust Score i bëri turneut më të drejtë. Nuk ka më kapje false — të gjithë shohin menjëherë nëse kapja është e verifikuar me GPS." },
