    "features": { "title": "Alles wat je nodig hebt om beter te vissen", "1_title": "AI vangstlogger", "1_desc": "Maak een foto — de AI identificeert de soort, registreert maten en berekent automatisch je Strike Score.", "2_title": "Vangstprognose & getijtracking", "2_desc": "Solunaire fasen, getijkalenders, windprognoses en luchtdruktrends voor het perfecte vismoment.", "3_title": "Aas-intelligentie", "3_desc": "De app analyseert jouw vangsten en beveelt optimaal aas aan op basis van seizoen, waterlichaam en weer.", "4_title": "Trust Score systeem", "4_desc": "Geverifieerde vangsten via GPS & foto. Transparante community-beoordeling — eerlijk en vervalsingsbestendig.", "5_title": "Vergunningsbeheer", "5_desc": "Visvergunningen voor 14 landen direct in de app. Kopen, opslaan en tonen — zonder papierwerk.", "6_title": "Community & coaches", "6_desc": "Crews, toernooien, live chat en professionele vishengel-coaches voor je volgende sessie." },
    "how": { "label": "Hoe het werkt", "title": "Drie stappen naar de perfecte strike", "1_title": "Log je vangst", "1_desc": "Maak een foto, bevestig de soort, voer maten in. In minder dan 60 seconden is je vangst gedocumenteerd met weer, GPS en aas.", "2_title": "AI leert jouw profiel", "2_desc": "Na elke vangst wordt jouw persoonlijke vaardigheidsprofiel verfijnd. De AI analyseert patronen in jouw successen en mislukkingen.", "3_title": "De app vertelt je wanneer & waar", "3_desc": "Gepersonaliseerde Strike Score-prognoses: welke vis bijt, op welke plek, met welk aas? StrikeAhead weet het." },
    "testimonials": { "label": "Ervaringen", "title": "Wat vissers zeggen", "1_name": "Lars Bergmann", "1_role": "Hobbyvisser, Hamburg", "1_text": "Sinds ik StrikeAhead gebruik, is mijn vangstpercentage verdubbeld. De AI-voorspellingen zijn verrassend nauwkeurig.", "2_name": "Maria Hoffmann", "2_role": "Zeevisser, Kiel", "2_text": "De vergunningsbeheer alleen al is het abonnement waard. Ik vis in 5 verschillende landen en heb eindelijk alle vergunningen op één plek.", "3_name": "Stefan Kowalczyk", "3_role": "Toernooivisser, München", "3_text": "De Trust Score heeft toernooien eerlijker gemaakt. Geen neppe vangsten meer — iedereen ziet direct of een vangst GPS-geverifieerd is." },
