    "features": { "title": "Tout ce qu'il vous faut pour pêcher mieux", "1_title": "Logger de prises avec IA", "1_desc": "Prenez une photo — l'IA identifie l'espèce, enregistre les mesures et calcule votre Strike Score automatiquement.", "2_title": "Prévisions de prises & marées", "2_desc": "Phases solunaires, calendriers des marées, prévisions de vent et tendances de pression pour le moment idéal.", "3_title": "Intelligence appâts", "3_desc": "L'appli analyse vos prises et recommande l'appât optimal selon la saison, le plan d'eau et la météo.", "4_title": "Système de score de confiance", "4_desc": "Prises vérifiées par GPS et photo. Évaluation communautaire transparente — juste et infalsifiable.", "5_title": "Gestionnaire de licences", "5_desc": "Licences de pêche pour 14 pays directement dans l'appli. Achetez, stockez et présentez-les sans paperasse.", "6_title": "Communauté & coachs", "6_desc": "Équipages, tournois, chat en direct et coachs professionnels pour votre prochaine session." },
    "how": { "label": "Comment ça marche", "title": "Trois étapes vers le strike parfait", "1_title": "Enregistrez votre prise", "1_desc": "Prenez une photo, confirmez l'espèce, entrez les mesures. En moins de 60 secondes, votre prise est documentée avec météo, GPS et appât.", "2_title": "L'IA apprend votre profil", "2_desc": "Après chaque prise, votre profil de compétences personnel est affiné. L'IA analyse les schémas de vos succès et échecs.", "3_title": "L'appli vous dit quand et où", "3_desc": "Prévisions Strike Score personnalisées : quel poisson mord, à quel endroit, avec quel appât ? StrikeAhead le sait." },
    "testimonials": { "label": "Avis", "title": "Ce que disent les pêcheurs", "1_name": "Lars Bergmann", "1_role": "Pêcheur amateur, Hambourg", "1_text": "Depuis que j'utilise StrikeAhead, mon taux de prises a doublé. Les prédictions IA sont étonnamment précises.", "2_name": "Maria Hoffmann", "2_role": "Pêcheuse en mer, Kiel", "2_text": "Le gestionnaire de licences vaut à lui seul l'abonnement. Je pêche dans 5 pays différents et j'ai enfin tous mes permis en un seul endroit.", "3_name": "Stefan Kowalczyk", "3_role": "Pêcheur de tournoi, Munich", "3_text": "Le Trust Score a rendu les tournois plus équitables. Plus de fausses prises — tout le monde voit si une prise est vérifiée GPS." },
