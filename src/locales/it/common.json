    "features": { "title": "Tutto ciò di cui hai bisogno per pescare meglio", "1_title": "Logger catture con IA", "1_desc": "Scatta una foto — l'IA identifica la specie, registra le misure e calcola automaticamente il tuo Strike Score.", "2_title": "Previsioni catture e maree", "2_desc": "Fasi solunari, calendari delle maree, previsioni del vento e tendenze della pressione per il momento perfetto.", "3_title": "Intelligenza esca", "3_desc": "L'app analizza le tue catture e consiglia l'esca ottimale in base alla stagione, al corpo idrico e al meteo.", "4_title": "Sistema Trust Score", "4_desc": "Catture verificate tramite GPS e foto. Valutazione comunitaria trasparente — giusta e non falsificabile.", "5_title": "Gestore licenze", "5_desc": "Licenze di pesca per 14 paesi direttamente nell'app. Acquista, archivia e mostrali senza burocrazia.", "6_title": "Comunità & coach", "6_desc": "Equipaggi, tornei, chat dal vivo e coach professionisti per la tua prossima sessione." },
    "how": { "label": "Come funziona", "title": "Tre passi verso lo strike perfetto", "1_title": "Registra la tua cattura", "1_desc": "Scatta una foto, conferma la specie, inserisci le misure. In meno di 60 secondi la tua cattura è documentata con meteo, GPS ed esca.", "2_title": "L'IA impara il tuo profilo", "2_desc": "Dopo ogni cattura, il tuo profilo di abilità personale viene affinato. L'IA analizza i pattern nei tuoi successi e fallimenti.", "3_title": "L'app ti dice quando e dove", "3_desc": "Previsioni Strike Score personalizzate: quale pesce abbocca, in quale spot, con quale esca? StrikeAhead lo sa." },
